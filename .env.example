# Nexus.ai — Unified Environment Template

# ── Databricks (Core Data Layer) ──────────────────────────────────────────────
DATABRICKS_HOST=https://<your-workspace>.cloud.databricks.com
DATABRICKS_TOKEN=dapi<your-pat-token>
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/<your-warehouse-id>
DATABRICKS_CATALOG=nexus_catalog
DATABRICKS_SCHEMA=raw_data

# ── AI Model Providers ────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_3_1_pro_preview_key

# ── Authentication ────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=your_better_auth_secret_minimum_32_chars
BETTER_AUTH_URL=http://localhost:3004

# ── Clerk & Analytics (Optional/Legacy) ───────────────────────────────────────
CLERK_SECRET_KEY=...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=...
POSTHOG_KEY=...

# ── Slack Bot (Phase 1 MVP) ───────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_APP_TOKEN=xapp-...          

# Priority channel routing 
SLACK_P0_CHANNEL=#nexus-critical
SLACK_P1_CHANNEL=#nexus-alerts
SLACK_P2_CHANNEL=#nexus-triage
SLACK_P3_CHANNEL=#nexus-triage

SLACK_AUTO_ALERT=false

# ── Gmail (Phase 2 — Email Send) ──────────────────────────────────────────────
GMAIL_CLIENT_ID=<your-oauth2-client-id>.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=<your-oauth2-client-secret>
GMAIL_REFRESH_TOKEN=<your-long-lived-refresh-token>
GMAIL_FROM_ADDRESS=nexus-bot@yourcompany.com

# ── NIA Research Integration (Optional — web search / oracle) ─────────────────
NIA_API_KEY=<your-nia-api-key>
NIA_BASE_URL=https://apigcp.trynia.ai/v2

# ── Infrastructure ────────────────────────────────────────────────────────────
USE_LOCAL_DB=false
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxx...

# ── Server configuration ──────────────────────────────────────────────────────
# Ports are dynamically allocated by setup_and_run.js but can be forced here
# PORT=3001
# HONO_PORT=3002
